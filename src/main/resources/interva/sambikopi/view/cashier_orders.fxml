<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="interva.sambikopi.controller.CashierOrdersController"
      spacing="22.0"
      style="-fx-background-color:#F7F2EA; -fx-font-family:'Segoe UI';">

    <padding>
        <Insets bottom="35.0" left="36.0" right="36.0" top="35.0" />
    </padding>

    <VBox spacing="6.0">
        <Label text="Orders" style="-fx-font-size:32px; -fx-font-weight:bold; -fx-text-fill:#2D1B14;" />
        <Label text="Cashier order history and payment records." style="-fx-text-fill:#8A8178; -fx-font-size:15px;" />
    </VBox>

    <HBox spacing="12.0">
        <TextField fx:id="searchField" promptText="Search cashier orders..." prefHeight="42.0" prefWidth="520.0"
                   style="-fx-background-color:white; -fx-border-color:#E5D8C8; -fx-background-radius:9; -fx-border-radius:9;" />
        <Button fx:id="searchButton" onAction="#handleSearch" text="Search" prefHeight="42.0" prefWidth="100.0"
                style="-fx-background-color:#C96B43; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:9;" />
        <Button fx:id="refreshButton" onAction="#handleRefresh" text="Refresh" prefHeight="42.0" prefWidth="100.0"
                style="-fx-background-color:white; -fx-border-color:#D8B89A; -fx-text-fill:#2D1B14; -fx-font-weight:bold; -fx-background-radius:9; -fx-border-radius:9;" />
    </HBox>

    <Label fx:id="statusLabel" text="Cashier Orders ready." style="-fx-text-fill:#4F6448; -fx-font-weight:bold;" />

    <TableView fx:id="orderTable" prefHeight="430.0" prefWidth="980.0"
               style="-fx-background-color:white; -fx-border-color:#E5D8C8; -fx-border-radius:12; -fx-background-radius:12;">
        <columns>
            <TableColumn fx:id="colOrderId" text="ORDER ID" prefWidth="110.0" />
            <TableColumn fx:id="colCustomer" text="CUSTOMER" prefWidth="160.0" />
            <TableColumn fx:id="colProduct" text="PRODUCT" prefWidth="280.0" />
            <TableColumn fx:id="colCreationDate" text="CREATION DATE" prefWidth="160.0" />
            <TableColumn fx:id="colPayment" text="PAYMENT" prefWidth="100.0" />
            <TableColumn fx:id="colTotal" text="TOTAL" prefWidth="100.0" />
            <TableColumn fx:id="colStatus" text="STATUS" prefWidth="110.0" />
        </columns>
    </TableView>
</VBox>
