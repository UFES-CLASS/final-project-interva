<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1200.0"
            style="-fx-background-color:#F7F2EA;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="interva.sambikopi.controller.InventoryController">

    <left>
        <VBox prefWidth="220.0" spacing="15.0" style="-fx-background-color:#2D1B14;">
            <padding>
                <Insets bottom="25.0" left="15.0" right="15.0" top="25.0" />
            </padding>

            <Label text="Sambi Kopi" maxWidth="9999" alignment="CENTER"
                   style="-fx-font-size:24px; -fx-font-weight:bold; -fx-text-fill:white; -fx-alignment:center;" />
            <Separator />

            <Button fx:id="dashboardButton" onAction="#handleOpenDashboard" maxWidth="9999" text="Dashboard"
                    style="-fx-background-color:transparent; -fx-text-fill:white;" />
            <Button fx:id="menuButton" onAction="#handleOpenMenu" maxWidth="9999" text="Menu"
                    style="-fx-background-color:transparent; -fx-text-fill:white;" />
            <Button fx:id="menuListButton" onAction="#handleOpenMenuList" maxWidth="9999" text="Menu List"
                    style="-fx-background-color:transparent; -fx-text-fill:white;" />
            <Button fx:id="inventoryButton" onAction="#handleOpenInventory" maxWidth="9999" text="Inventory"
                    style="-fx-background-color:#C96B43; -fx-text-fill:white; -fx-background-radius:10;" />
            <Button fx:id="ordersButton" onAction="#handleOpenOrders" maxWidth="9999" text="Orders"
                    style="-fx-background-color:transparent; -fx-text-fill:white;" />
        </VBox>
    </left>

    <center>
        <VBox spacing="20.0">
            <padding>
                <Insets bottom="35.0" left="35.0" right="35.0" top="35.0" />
            </padding>

            <VBox spacing="5.0">
                <Label text="Inventory Management" style="-fx-font-size:30px; -fx-font-weight:bold; -fx-text-fill:#2D1B14;" />
                <Label text="Monitor stock levels and expiration dates" style="-fx-font-size:14px; -fx-text-fill:#666666;" />
            </VBox>

            <HBox spacing="10.0">
                <TextField fx:id="inventorySearchField" prefWidth="250.0" promptText="Search product..."
                           style="-fx-background-color:white; -fx-border-color:#E5D8C8; -fx-border-radius:8; -fx-background-radius:8;" />
                <Button fx:id="inventorySearchButton" onAction="#handleInventorySearch" text="Search"
                        style="-fx-background-color:#C96B43; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8;" />
            </HBox>

            <Label fx:id="inventoryStatusLabel" text="Inventory ready."
                   style="-fx-text-fill:#5E8B5A; -fx-font-weight:bold;" />

            <TableView fx:id="inventoryTable" prefHeight="430.0"
                       style="-fx-background-color:white; -fx-border-color:#E5D8C8; -fx-border-radius:10; -fx-background-radius:10;">
                <columns>
                    <TableColumn fx:id="productColumn" prefWidth="330.0" text="PRODUCT" />
                    <TableColumn fx:id="stockColumn" prefWidth="130.0" text="STOCK" />
                    <TableColumn fx:id="expDateColumn" prefWidth="210.0" text="EXP DATE" />
                    <TableColumn fx:id="statusColumn" prefWidth="230.0" text="STATUS" />
                </columns>
            </TableView>

            <HBox spacing="10.0">
                <Button fx:id="checkStockButton" onAction="#handleCheckStock" text="Check Stock"
                        style="-fx-background-color:white; -fx-border-color:#C96B43; -fx-text-fill:#C96B43; -fx-border-radius:8; -fx-background-radius:8;" />
                <Button fx:id="addStockButton" onAction="#handleAddStock" text="Add Stock"
                        style="-fx-background-color:#C96B43; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8;" />
                <Button fx:id="notifyOwnerButton" onAction="#handleNotifyOwner" text="Notify Owner"
                        style="-fx-background-color:#2D1B14; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8;" />
            </HBox>
        </VBox>
    </center>
</BorderPane>
