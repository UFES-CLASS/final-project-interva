<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1200.0"
            style="-fx-background-color:#F7F2EA;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="interva.sambikopi.controller.MenuController">

    <left>
        <VBox prefWidth="220.0" spacing="15.0" style="-fx-background-color:#2D1B14;">
            <padding>
                <Insets bottom="25.0" left="15.0" right="15.0" top="25.0" />
            </padding>

            <Label text="Sambi Kopi" maxWidth="9999" alignment="CENTER"
                   style="-fx-font-size:24px; -fx-font-weight:bold; -fx-text-fill:white; -fx-alignment:center;" />
            <Separator />

            <Button fx:id="dashboardButton" onAction="#handleOpenDashboard" maxWidth="9999" text="Dashboard"
                    style="-fx-background-color:transparent; -fx-text-fill:white;" />
            <Button fx:id="menuButton" onAction="#handleOpenMenu" maxWidth="9999" text="Menu"
                    style="-fx-background-color:#C96B43; -fx-text-fill:white; -fx-background-radius:10;" />
            <Button fx:id="inventoryButton" onAction="#handleOpenInventory" maxWidth="9999" text="Inventory"
                    style="-fx-background-color:transparent; -fx-text-fill:white;" />
            <Button fx:id="ordersButton" onAction="#handleOpenOrders" maxWidth="9999" text="Orders"
                    style="-fx-background-color:transparent; -fx-text-fill:white;" />
        </VBox>
    </left>

    <center>
        <VBox spacing="16.0">
            <padding>
                <Insets bottom="30.0" left="35.0" right="35.0" top="30.0" />
            </padding>

            <VBox spacing="5.0">
                <Label text="Add New Menu" style="-fx-font-size:34px; -fx-font-weight:bold; -fx-text-fill:#2D1B14;" />
                <Label text="Fix the flagged fields, then confirm again." style="-fx-text-fill:#666666; -fx-font-size:15px;" />
            </VBox>

            <HBox fx:id="messageBox" alignment="CENTER" spacing="10.0"
                  style="-fx-background-color:#EEF7EA; -fx-border-color:#D7EBCF; -fx-border-radius:10; -fx-background-radius:10;">
                <padding>
                    <Insets bottom="12.0" left="15.0" right="15.0" top="12.0" />
                </padding>
                <Label fx:id="messageLabel" maxWidth="9999" text="Fill the menu data, then confirm again."
                       alignment="CENTER" wrapText="true" style="-fx-text-fill:#4F8B45; -fx-font-weight:bold; -fx-alignment:center;" />
            </HBox>

            <HBox spacing="15.0">
                <VBox spacing="5.0">
                    <Label text="MENU NAME" style="-fx-font-weight:bold;" />
                    <TextField fx:id="menuNameField" prefHeight="42.0" prefWidth="330.0" promptText="Kopi Milk Gula Aren"
                               style="-fx-background-color:white; -fx-border-color:#E5D8C8; -fx-border-radius:8; -fx-background-radius:8;" />
                </VBox>

                <VBox spacing="5.0">
                    <Label text="CATEGORY" style="-fx-font-weight:bold;" />
                    <ComboBox fx:id="categoryComboBox" prefHeight="42.0" prefWidth="260.0" promptText="Beverage - Coffee"
                              style="-fx-background-color:white; -fx-border-color:#E5D8C8; -fx-border-radius:8; -fx-background-radius:8;" />
                </VBox>

                <VBox spacing="5.0">
                    <Label text="PRICE (IDR)" style="-fx-font-weight:bold;" />
                    <TextField fx:id="priceField" prefHeight="42.0" prefWidth="140.0" promptText="18000"
                               style="-fx-background-color:white; -fx-border-color:#E5D8C8; -fx-border-radius:8; -fx-background-radius:8;" />
                </VBox>
            </HBox>

            <VBox spacing="5.0">
                <Label text="INGREDIENTS" style="-fx-font-weight:bold; -fx-text-fill:#C65D42;" />
                <TextField fx:id="ingredientsField" prefHeight="42.0" promptText="Milk, Coffee, Palm Sugar"
                           style="-fx-background-color:white; -fx-border-color:#C65D42; -fx-border-radius:8; -fx-background-radius:8;" />
            </VBox>

            <HBox spacing="12.0">
                <Button fx:id="confirmAgainButton" onAction="#handleConfirmAgain" prefHeight="42.0" prefWidth="160.0" text="Confirm Again"
                        style="-fx-background-color:#C96B43; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10;" />
                <Button fx:id="cancelButton" onAction="#handleCancel" prefHeight="42.0" prefWidth="110.0" text="Cancel"
                        style="-fx-background-color:white; -fx-border-color:#DDDDDD; -fx-background-radius:10; -fx-border-radius:10;" />
                <Button fx:id="deleteMenuButton" onAction="#handleDeleteMenu" prefHeight="42.0" prefWidth="120.0" text="Delete"
                        style="-fx-background-color:#D94141; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10;" />
            </HBox>

            <HBox spacing="10.0">
                <TextField fx:id="menuSearchField" prefWidth="250.0" promptText="Search menu..."
                           style="-fx-background-color:white; -fx-border-color:#E5D8C8; -fx-border-radius:8; -fx-background-radius:8;" />
                <Button fx:id="menuSearchButton" onAction="#handleSearchMenu" text="Search"
                        style="-fx-background-color:#C96B43; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8;" />
                <Button fx:id="refreshMenuButton" onAction="#handleRefreshMenu" text="Refresh"
                        style="-fx-background-color:white; -fx-border-color:#C96B43; -fx-text-fill:#C96B43; -fx-border-radius:8; -fx-background-radius:8;" />
            </HBox>

            <TableView fx:id="menuTable" prefHeight="250.0"
                       style="-fx-background-color:white; -fx-border-color:#E5D8C8; -fx-border-radius:10; -fx-background-radius:10;">
                <columns>
                    <TableColumn fx:id="menuNameColumn" prefWidth="230.0" text="MENU NAME" />
                    <TableColumn fx:id="categoryColumn" prefWidth="200.0" text="CATEGORY" />
                    <TableColumn fx:id="priceColumn" prefWidth="100.0" text="PRICE (IDR)" />
                    <TableColumn fx:id="ingredientsColumn" prefWidth="260.0" text="INGREDIENTS" />
                    <TableColumn fx:id="statusColumn" prefWidth="160.0" text="STATUS" />
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
