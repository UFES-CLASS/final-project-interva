<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="interva.sambikopi.controller.OwnerReviewMenuController"
      spacing="22.0"
      style="-fx-background-color:#F7F2EA; -fx-font-family:'Segoe UI';">

    <padding>
        <Insets bottom="35.0" left="36.0" right="36.0" top="35.0" />
    </padding>

    <VBox spacing="6.0">
        <Label text="Review New Menu" style="-fx-font-size:32px; -fx-font-weight:bold; -fx-text-fill:#2D1B14;" />
        <Label text="Approve or reject new menu requests saved by Barista." style="-fx-text-fill:#8A8178; -fx-font-size:15px;" />
    </VBox>

    <HBox spacing="12.0">
        <TextField fx:id="searchField" promptText="Search menu review request..." prefHeight="42.0" prefWidth="430.0"
                   style="-fx-background-color:white; -fx-border-color:#E5D8C8; -fx-background-radius:9; -fx-border-radius:9;" />
        <Button fx:id="searchButton" onAction="#handleSearch" text="Search" prefHeight="42.0" prefWidth="100.0"
                style="-fx-background-color:#C96B43; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:9;" />
        <Button fx:id="refreshButton" onAction="#handleRefresh" text="Refresh" prefHeight="42.0" prefWidth="100.0"
                style="-fx-background-color:white; -fx-border-color:#D8B89A; -fx-text-fill:#2D1B14; -fx-font-weight:bold; -fx-background-radius:9; -fx-border-radius:9;" />
    </HBox>

    <Label fx:id="statusLabel" text="Review new menu requests from Barista." wrapText="true" style="-fx-text-fill:#4F6448; -fx-font-weight:bold;" />

    <TableView fx:id="menuReviewTable" prefHeight="430.0" prefWidth="980.0"
               style="-fx-background-color:white; -fx-border-color:#E5D8C8; -fx-border-radius:12; -fx-background-radius:12;">
        <columns>
            <TableColumn fx:id="colMenuName" text="MENU NAME" prefWidth="230.0" />
            <TableColumn fx:id="colCategory" text="CATEGORY" prefWidth="160.0" />
            <TableColumn fx:id="colPrice" text="PRICE" prefWidth="130.0" />
            <TableColumn fx:id="colIngredients" text="INGREDIENTS" prefWidth="310.0" />
            <TableColumn fx:id="colStatus" text="STATUS" prefWidth="160.0" />
        </columns>
    </TableView>

    <HBox spacing="14.0">
        <Button fx:id="approveButton" onAction="#handleApproveMenu" text="Approve" prefHeight="46.0" prefWidth="150.0"
                style="-fx-background-color:#7D9B76; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10;" />
        <Button fx:id="rejectButton" onAction="#handleRejectMenu" text="Reject" prefHeight="46.0" prefWidth="150.0"
                style="-fx-background-color:#C98D88; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10;" />
    </HBox>
</VBox>
