<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="700.0" prefWidth="1200.0"
           xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="interva.sambikopi.controller.OrdersController">

    <BorderPane prefHeight="700.0" prefWidth="1200.0" style="-fx-background-color:#E9E5D8;">
        <left>
            <VBox prefWidth="220.0" spacing="24.0" style="-fx-background-color:#DDD7C8; -fx-border-color:#A79E91; -fx-border-width:0 1 0 0;">
                <padding>
                    <Insets bottom="30.0" left="20.0" right="20.0" top="35.0" />
                </padding>

                <Label text="SAMBI KOPI" maxWidth="9999" alignment="CENTER"
                       style="-fx-font-family:Georgia; -fx-font-size:25px; -fx-letter-spacing:3px; -fx-text-fill:#2E241D; -fx-alignment:center;" />
                <Separator style="-fx-background-color:#A79E91;" />

                <Button fx:id="dashboardButton" onAction="#handleOpenDashboard" maxWidth="9999" prefHeight="45.0" text="DASHBOARD"
                        style="-fx-font-family:Georgia; -fx-font-size:16px; -fx-background-color:#F4F1EA; -fx-text-fill:#2E241D; -fx-background-radius:8; -fx-border-radius:8;" />
                <Button fx:id="menuButton" onAction="#handleOpenMenu" maxWidth="9999" prefHeight="45.0" text="MENU"
                        style="-fx-font-family:Georgia; -fx-font-size:16px; -fx-background-color:#F4F1EA; -fx-text-fill:#2E241D; -fx-background-radius:8; -fx-border-radius:8;" />
                <Button fx:id="inventoryButton" onAction="#handleOpenInventory" maxWidth="9999" prefHeight="45.0" text="INVENTORY"
                        style="-fx-font-family:Georgia; -fx-font-size:16px; -fx-background-color:#F4F1EA; -fx-text-fill:#2E241D; -fx-background-radius:8; -fx-border-radius:8;" />
                <Button fx:id="ordersButton" onAction="#handleOpenOrders" maxWidth="9999" prefHeight="45.0" text="ORDERS"
                        style="-fx-font-family:Georgia; -fx-font-size:16px; -fx-background-color:#F4F1EA; -fx-text-fill:#2E241D; -fx-border-color:#C98963; -fx-background-radius:8; -fx-border-radius:8; -fx-border-width:1.5;" />
            </VBox>
        </left>

        <center>
            <VBox spacing="22.0">
                <padding>
                    <Insets bottom="45.0" left="45.0" right="45.0" top="45.0" />
                </padding>

                <Label text="ORDERS"
                       style="-fx-font-family:Georgia; -fx-font-size:32px; -fx-letter-spacing:5px; -fx-text-fill:#2E241D;" />

                <HBox spacing="14.0">
                    <TextField fx:id="orderSearchField" prefHeight="44.0" prefWidth="455.0"
                               promptText="Search Order ID, customer, or menu..."
                               style="-fx-background-color:#F4F1EA; -fx-border-color:#D8B89A; -fx-border-radius:8; -fx-background-radius:8; -fx-prompt-text-fill:#8A8178;" />

                    <Button fx:id="searchOrderButton" onAction="#handleSearchOrders" prefHeight="44.0" prefWidth="92.0" text="Search"
                            style="-fx-background-color:#C98963; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8;" />

                    <Button fx:id="filterButton" onAction="#handleFilterOrders" prefHeight="44.0" prefWidth="110.0" text="Filters"
                            style="-fx-background-color:#F4F1EA; -fx-border-color:#C98963; -fx-text-fill:#2E241D; -fx-border-radius:8; -fx-background-radius:8;" />

                    <Button fx:id="refreshOrderButton" onAction="#handleRefreshOrders" prefHeight="44.0" prefWidth="92.0" text="Refresh"
                            style="-fx-background-color:#F4F1EA; -fx-border-color:#A79E91; -fx-text-fill:#2E241D; -fx-border-radius:8; -fx-background-radius:8;" />

                    <Button fx:id="orderPanelButton" onAction="#handleShowOrderPanel" prefHeight="44.0" prefWidth="145.0" text="Orders"
                            style="-fx-background-color:#D9A382; -fx-text-fill:#4C3426; -fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8;" />
                </HBox>

                <Label fx:id="orderStatusLabel" text="Orders page ready."
                       style="-fx-text-fill:#4F6448; -fx-font-weight:bold;" />

                <TableView fx:id="orderTable" prefHeight="360.0"
                           style="-fx-background-color:#F4F1EA; -fx-border-color:#A79E91; -fx-border-radius:10; -fx-background-radius:10;">
                    <columns>
                        <TableColumn fx:id="orderIdColumn" prefWidth="170.0" text="ORDER ID" />
                        <TableColumn fx:id="customerColumn" prefWidth="220.0" text="CUSTOMER" />
                        <TableColumn fx:id="productColumn" prefWidth="260.0" text="PRODUCT" />
                        <TableColumn fx:id="creationDateColumn" prefWidth="220.0" text="CREATION DATE" />
                        <TableColumn fx:id="orderStatusColumn" prefWidth="160.0" text="STATUS" />
                    </columns>
                </TableView>

                <HBox spacing="12.0">
                    <Button fx:id="completeOrderButton" onAction="#handleCompleteOrder" prefHeight="42.0" prefWidth="130.0" text="Complete"
                            style="-fx-background-color:#7D9B76; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8;" />
                    <Button fx:id="assignOrderButton" onAction="#handleAssignOrder" prefHeight="42.0" prefWidth="130.0" text="Assign"
                            style="-fx-background-color:#C98963; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8;" />
                    <Button fx:id="cancelOrderButton" onAction="#handleCancelOrder" prefHeight="42.0" prefWidth="130.0" text="Cancel"
                            style="-fx-background-color:#C98D88; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:8;" />
                </HBox>
            </VBox>
        </center>
    </BorderPane>

    <VBox fx:id="orderPopupPane" visible="false" managed="false" prefWidth="540.0" maxWidth="540.0" prefHeight="365.0" maxHeight="365.0"
          StackPane.alignment="CENTER_RIGHT"
          style="-fx-background-color:#E0A27E; -fx-border-color:#5B463A; -fx-border-radius:10; -fx-background-radius:10; -fx-effect:dropshadow(three-pass-box, rgba(46,36,29,0.25), 16, 0, 0, 4);">
        <padding>
            <Insets bottom="18.0" left="18.0" right="18.0" top="16.0" />
        </padding>

        <HBox spacing="12.0" style="-fx-border-color:#5B463A; -fx-border-width:0 0 1 0; -fx-padding:0 0 12 0;">
            <Label text="Filters" style="-fx-text-fill:#5B463A; -fx-font-weight:bold;" />
            <Label text="ORDERS" style="-fx-text-fill:#4C3426; -fx-font-size:14px; -fx-font-weight:bold;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="closeOrderPanelButton" onAction="#handleHideOrderPanel" text="Back"
                    style="-fx-background-color:transparent; -fx-text-fill:#2E241D; -fx-font-weight:bold; -fx-font-size:15px;" />
        </HBox>

        <HBox spacing="14.0" style="-fx-padding:16 0 12 0; -fx-border-color:#6E655C; -fx-border-width:0 0 1 0;">
            <Label fx:id="popupOrderIdLabel" prefWidth="95.0" text="09213-AB" style="-fx-text-fill:#1F1712; -fx-font-weight:bold;" />
            <Label fx:id="popupCustomerLabel" prefWidth="105.0" text="Neon Sylvon" style="-fx-text-fill:#1F1712; -fx-font-weight:bold;" />
            <Label fx:id="popupProductLabel" prefWidth="115.0" text="Mineral Water" style="-fx-text-fill:#1F1712; -fx-font-weight:bold;" />
            <Label fx:id="popupDateLabel" prefWidth="120.0" text="16 January 2028" style="-fx-text-fill:#1F1712; -fx-font-weight:bold;" />
            <Button fx:id="popupCompleteButton" onAction="#handlePopupComplete" prefWidth="38.0" text="OK"
                    style="-fx-background-color:#83D982; -fx-text-fill:#1F3B20; -fx-font-weight:bold; -fx-background-radius:18;" />
            <Button fx:id="popupCancelButton" onAction="#handlePopupCancel" prefWidth="38.0" text="X"
                    style="-fx-background-color:#EA6B78; -fx-text-fill:#2E241D; -fx-font-weight:bold; -fx-background-radius:18;" />
        </HBox>

        <VBox spacing="0" style="-fx-padding:12 0 0 0;">
            <HBox spacing="20" style="-fx-padding:12 0 12 0; -fx-border-color:rgba(91,70,58,0.25); -fx-border-width:0 0 1 0;">
                <Label text="Espresso Con Panna" prefWidth="230" style="-fx-text-fill:rgba(46,36,29,0.45);" />
                <Label text="16 January 2028" prefWidth="150" style="-fx-text-fill:rgba(46,36,29,0.45);" />
                <Label text="Complete" style="-fx-background-color:rgba(244,241,234,0.35); -fx-background-radius:12; -fx-padding:4 12 4 12; -fx-text-fill:rgba(46,36,29,0.45);" />
            </HBox>
            <HBox spacing="20" style="-fx-padding:12 0 12 0; -fx-border-color:rgba(91,70,58,0.25); -fx-border-width:0 0 1 0;">
                <Label text="Milkshake Vanilla" prefWidth="230" style="-fx-text-fill:rgba(46,36,29,0.45);" />
                <Label text="16 January 2028" prefWidth="150" style="-fx-text-fill:rgba(46,36,29,0.45);" />
                <Label text="Assigned" style="-fx-background-color:rgba(244,241,234,0.35); -fx-background-radius:12; -fx-padding:4 12 4 12; -fx-text-fill:rgba(46,36,29,0.45);" />
            </HBox>
            <Label fx:id="popupStatusLabel" text="Select an order, then complete or cancel it here."
                   style="-fx-padding:20 0 0 0; -fx-text-fill:#5B463A; -fx-font-weight:bold;" />
        </VBox>
    </VBox>
</StackPane>
